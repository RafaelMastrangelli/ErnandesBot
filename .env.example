# Server
HOST=0.0.0.0
PORT=3005
JSON_BODY_LIMIT=1mb

# Webhook / Git
# Valores aceitos: github | bitbucket
GIT_PROVIDER=github
GITHUB_WEBHOOK_EVENT=push
BITBUCKET_WEBHOOK_EVENT_KEY=repo:push

# Worker / fila
MAX_QUEUE_SIZE=1000
MAX_PROCESSING_RETRIES=2

# RabbitMQ
RABBITMQ_USER=ai-doc
RABBITMQ_PASS=ai-doc
RABBITMQ_URL=amqp://ai-doc:ai-doc@localhost:5672
RABBITMQ_QUEUE=ai-doc-agent.events
RABBITMQ_DLX=ai-doc-agent.dlx
RABBITMQ_DLQ=ai-doc-agent.events.dlq
RABBITMQ_DLQ_ROUTING_KEY=events.failed

# Diff
MAX_DIFF_SIZE=20000
IGNORED_DIFF_PATHS=node_modules,dist,build,.git,.next,coverage

# Workspace local de clone
WORKSPACE_DIR=src/workspace

# LLM — escolha UM provider e configure apenas o bloco correspondente
# Valores aceitos: openai | groq
LLM_PROVIDER=groq

# --- Groq (necessario apenas se LLM_PROVIDER=groq) ---
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_MAX_OUTPUT_TOKENS=1200

# --- OpenAI (necessario apenas se LLM_PROVIDER=openai) ---
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
OPENAI_MAX_OUTPUT_TOKENS=1200

# Docker (montagem de chaves SSH para clone GitHub/Bitbucket)
SSH_KEY_DIR=./.ssh
