# Server
HOST=0.0.0.0
PORT=3005
JSON_BODY_LIMIT=1mb

# Webhook / Git
# Valores aceitos: github | bitbucket
GIT_PROVIDER=github
GITHUB_WEBHOOK_EVENT=push
BITBUCKET_WEBHOOK_EVENT_KEY=repo:push

# Worker / fila
MAX_QUEUE_SIZE=1000
MAX_PROCESSING_RETRIES=2

# RabbitMQ
RABBITMQ_USER=ai-doc
RABBITMQ_PASS=ai-doc
RABBITMQ_URL=amqp://ai-doc:ai-doc@localhost:5672
RABBITMQ_QUEUE=ai-doc-agent.events
RABBITMQ_DLX=ai-doc-agent.dlx
RABBITMQ_DLQ=ai-doc-agent.events.dlq
RABBITMQ_DLQ_ROUTING_KEY=events.failed

# Diff
MAX_DIFF_SIZE=20000
IGNORED_DIFF_PATHS=node_modules,dist,build,.git,.next,coverage

# Workspace local de clone
WORKSPACE_DIR=src/workspace

# Documentacao
DOC_TARGET_FILE=README.md
DOC_CONTEXT_FILES=
DOC_GIT_USER_NAME=ai-doc-agent
DOC_GIT_USER_EMAIL=ai-doc-agent@local
DOC_COMMIT_MESSAGE=docs: atualizacao automatica
DOC_SKIP_MARKER=[ai-doc-agent]
DOC_AUTO_PUSH=true

# Branch de documentacao
# dedicated = commit em branch separada para revisar via PR
# same = commit direto na branch do push (ex: main)
DOC_BRANCH_STRATEGY=dedicated
DOC_BRANCH=docs/auto-update

# LLM — escolha UM provider e configure apenas o bloco correspondente
# Valores aceitos: openai | groq
LLM_PROVIDER=groq

# --- Groq (necessario apenas se LLM_PROVIDER=groq) ---
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_MAX_OUTPUT_TOKENS=4096

# --- OpenAI (necessario apenas se LLM_PROVIDER=openai) ---
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
OPENAI_MAX_OUTPUT_TOKENS=4096

# Docker (montagem de chaves SSH para clone GitHub/Bitbucket)
SSH_KEY_DIR=./.ssh
